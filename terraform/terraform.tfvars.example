project_name = "instaclone"
aws_region   = "ap-southeast-1"
environment  = "prod"
vpc_cidr     = "10.0.0.0/16"

# Sensitive — set via TF_VAR_db_password and TF_VAR_jwt_key env vars
# db_password = ""
# jwt_key     = ""

# Optional — leave empty to skip DNS/SSL
# domain_name = "instaclone.example.com"
